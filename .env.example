CODA_API_TOKEN=replace-with-coda-api-token
CODA_WORKSPACE_ID=
CODA_INTERNAL_DOMAINS=example.com
UNUSED_AFTER_DAYS=90
POLL_INTERVAL_SECONDS=3600
SCAN_ON_STARTUP=true
SCAN_PAGES=true
PAGE_EXPORT_FORMAT=markdown
MAX_ROWS_PER_TABLE=500
REMEDIATION_DRY_RUN=true
DESTRUCTIVE_REMEDIATION_ENABLED=false
SQLITE_PATH=data/securecoda.db
LOG_FILE=logs/securecoda.log
SLACK_WEBHOOK_URL=

